    <% layout("/layouts/boilerplate") -%>

      <div class="row mt-3">
    <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1" >
        <h3>Edit your listing</h3>

    <form method="post" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation">
        
         <div class="mb-3">
              <label for="title" class="form-label">Title</label>
              <input type="text" name="listing[title]" value="<%=listing.title %>" class="form-control" required >
               <div class="invalid-feedback">
                   This field is required.</div>
         </div>
       
       <div class="mb-3">
        <label for="description" class="form-label">Description</label> 
         <textarea  name="listing[description]" type="text" class="form-control" required><%=listing.description %></textarea>
                  <div class="invalid-feedback"> Plese enter a short description.</div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Image link</label>
        <input id="image" type="text" name="listing[image][url]" class="form-control" value="<%= listing.image.url %>">
      </div>

      <div class="row">
         <div class="mb-3 col-md-4"> 
            <label for="price" class="form-label">Price</label> 
             <input type="number" name="listing[price]" class="form-control" required value="<%=listing.price %>" >
                      <div class="invalid-feedback">Price should be valid.</div>
         </div>
        
        
        <div class="mb-3 col-md-8" >
          <label for="country" class="form-label">Country</label>
          <input type="text" name="listing[country]"class="form-control" required value="<%=listing.country %>">
                <div class="invalid-feedback"> Country name should be valid.</div>
        </div>
           </div>
        
         
         <div class="mb-3">
             <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" class="form-control" required value="<%=listing.location %>">
                        <div class="invalid-feedback">Loccation should be valid.</div>
         </div>
         
         <button class="btn btn-dark mt-3 edit-btn ">Edit</button>
        
    </form>
    </div>
    </div>
    
