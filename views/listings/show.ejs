<% layout("/layouts/boilerplate") -%>

<div class="row mt-4 justify-content-center">
  <div class="col-md-6">
<div class="show-card">

  <h3 class="mb-3"><%= listing.title %></h3>

  <div class="card shadow-sm">
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
    >

    <div class="card-body">

      <p class="card-text">
        <%= listing.description %>
      </p>

      <p class="fw-semibold mb-1">
        ₹ <%= listing.price.toLocaleString("en-IN") %>
      </p>

      <p class="text-muted mb-0">
        <%= listing.location %>, <%= listing.country %>
      </p>

    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
      Edit
    </a>

    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-danger">
        Delete
      </button>
    </form>
  </div>

  <hr class="mt-4">

  <h4 class="mb-4 text-center">Leave a Review</h4>

  <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">

    <div class="mb-3">
      <label for="rating" class="form-label">Rating</label>
      <input 
        type="range" 
        min="1" 
        max="5" 
        id="rating" 
        name="review[rating]" 
        class="form-range">
    </div>

    <div class="mb-3">
      <label for="comment" class="form-label">Comments</label>
      <textarea 
        name="review[comment]" 
        id="comment"   
        class="form-control"
        rows="5"
        required
        >
      
      </textarea>
      <div class="invalid-feedback">Please add some comments for review</div>
    </div>

    <button class="btn btn-dark">
      Submit
    </button>

  </form>
</div>
<hr>

<p class="fw-bold fs-5">All Reviews</p>

<% for (let review of listing.reviews) { %>

  <div class="card mb-3 shadow-sm">
    <div class="card-body mb-6 ">

      <h5 class="card-title text-primary">Jhon Doe</h5>

      <p class="card-text mb-2">
        <%= review.comment %>
      </p>

      <p class="card-text">
        ⭐ <%= review.rating %> / 5
      </p>

    </div>
    
    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
  <button class="btn btn-sm btn-dark mb-3">Delete</button>
</form>
    </form>
  </div>

<% } %>

  </div>
</div>
